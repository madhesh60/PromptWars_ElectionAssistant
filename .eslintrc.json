{
  "env": {
    "browser": true,
    "commonjs": true,
    "es2021": true,
    "node": true
  },
  "extends": ["airbnb-base", "prettier"],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "globals": {
    "THREE": "readonly",
    "gsap": "readonly",
    "pdfjsLib": "readonly"
  },
  "rules": {
    "no-console": "off",
    "consistent-return": "off",
    "no-use-before-define": "off",
    "no-param-reassign": "off",
    "no-plusplus": "off",
    "no-underscore-dangle": "off",
    "no-restricted-globals": "off",
    "func-names": "off",
    "no-unused-vars": "off",
    "no-return-assign": "off",
    "no-nested-ternary": "off",
    "no-await-in-loop": "off",
    "no-return-await": "off",
    "no-alert": "off"
  }
}
